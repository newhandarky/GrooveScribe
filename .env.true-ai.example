# GrooveScribe local-first V1 true-AI enablement.
# Copy the values you need into your local shell or untracked .env file.
# True AI remains opt-in; mock-ai stays the default V1 development path.

AI_PYTHON=.venv-ai/bin/python

# Use cpu first for reproducible local setup. Switch to mps/cuda only after smoke is stable.
GROOVESCRIBE_DEMUCS_DEVICE=cpu
GROOVESCRIBE_ADTOF_DEVICE=cpu
GROOVESCRIBE_ADTOF_THRESHOLD=0.5

# The template must include {input} and {output}. Optional placeholders:
# {device}, {threshold}, {checkpoint}
GROOVESCRIBE_ADTOF_COMMAND_TEMPLATE=".venv-ai/bin/python -m adtof transcribe --input {input} --output {output} --device {device} --threshold {threshold}"

# Optional, only when your ADTOF install requires a checkpoint.
# GROOVESCRIBE_ADTOF_CHECKPOINT=/path/to/adtof/checkpoint.ckpt

# Must point to a drums stem, not a full mix. Generate it with:
# .venv-ai/bin/python scripts/prepare_adtof_verify_input.py --input tests/pipeline/fixtures/audio/synthetic_clean_drum_pattern.wav --device cpu
GROOVESCRIBE_ADTOF_VERIFY_INPUT=/tmp/groovescribe-stems/drums.wav
GROOVESCRIBE_ADTOF_VERIFY_OUTPUT_DIR=/tmp/groovescribe-adtof-verify

# PDF remains optional; leave empty unless MuseScore is outside PATH.
# GROOVESCRIBE_PDF_RENDERER=/Applications/MuseScore 4.app/Contents/MacOS/mscore
