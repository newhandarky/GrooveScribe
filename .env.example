# Shared
APP_ENV=local
LOG_LEVEL=info

# Backend
DATABASE_URL=postgresql+psycopg://groovescribe:groovescribe@localhost:5432/groovescribe
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
STORAGE_ROOT=./storage/local
API_HOST=0.0.0.0
API_PORT=8000

# Worker
WORKER_CONCURRENCY=1
CELERY_TASK_DEFAULT_QUEUE=groovescribe
CELERY_TASK_TIME_LIMIT_SECONDS=3600
CELERY_TASK_SOFT_TIME_LIMIT_SECONDS=3300
PIPELINE_VERSION=local-poc
AI_DEVICE=cpu

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api/v1
