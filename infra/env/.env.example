APP_ENV=local
DATABASE_URL=postgresql+psycopg://groovescribe:groovescribe@postgres:5432/groovescribe
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
STORAGE_ROOT=/app/storage/local
WORKER_CONCURRENCY=1
CELERY_TASK_DEFAULT_QUEUE=groovescribe
CELERY_TASK_TIME_LIMIT_SECONDS=3600
CELERY_TASK_SOFT_TIME_LIMIT_SECONDS=3300
PIPELINE_VERSION=local-poc
VITE_API_BASE_URL=http://localhost:8000/api/v1
